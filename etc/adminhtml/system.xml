<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="etechflow" translate="label" sortOrder="400">
            <label>eTechFlow</label>
        </tab>
        <section id="etechflow_orderemaileditor"
                 translate="label"
                 type="text"
                 sortOrder="170"
                 showInDefault="1"
                 showInWebsite="0"
                 showInStore="0">
            <label>Order Email Editor</label>
            <tab>etechflow</tab>
            <resource>ETechFlow_OrderEmailEditor::config</resource>

            <!-- ============================================================
                 LICENSE
            ============================================================ -->
            <group id="license" translate="label" type="text" sortOrder="5"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>License</label>
                <field id="license_key" translate="label comment tooltip" type="text" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Key</label>
                    <tooltip>Paste your eTechFlow SP-XXXX subscription key (auto-saved after Stripe payment) or a per-module/bundle key.</tooltip>
                    <comment><![CDATA[Paste your eTechFlow SP-XXXX subscription key (generated automatically after Stripe payment) OR a per-module HMAC key. Bundle key also accepted. Get one at <a href="https://etechflow.com" target="_blank">etechflow.com</a>.]]></comment>
                </field>
                <field id="issued_key" translate="label comment" type="obscure" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Issued Key (auto)</label>
                    <comment><![CDATA[Set automatically on first successful validation. Used to restore the key after an IP-block event. Do not edit.]]></comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="portal_url" translate="label comment" type="text" sortOrder="25"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Portal URL</label>
                    <comment><![CDATA[eTechFlow licensing portal endpoint. Update if your portal URL changes.]]></comment>
                </field>
                <field id="bundle_license_key" translate="label comment" type="obscure" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Bundle License Key</label>
                    <comment><![CDATA[Shared key that activates every eTechFlow module on this host. Set EITHER this OR the per-module key above.]]></comment>
                    <config_path>etechflow_bundle/license/license_key</config_path>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
            </group>

            <!-- ============================================================
                 PAYMENT (STRIPE)
            ============================================================ -->

            <group id="general"
                   translate="label"
                   type="text"
                   sortOrder="10"
                   showInDefault="1"
                   showInWebsite="0"
                   showInStore="0">
                <label>General Settings</label>
                <field id="enabled"
                       translate="label comment tooltip"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="0"
                       showInStore="0">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <tooltip>Master on/off switch. No = the Edit Email button + history menu hide.</tooltip>
                    <comment><![CDATA[
                        Master on/off switch.<br/>
                        <strong>Yes</strong> = the module runs: the Edit Email button appears on admin
                        order detail pages, the history menu appears under eTechFlow.<br/>
                        <strong>No</strong> = the module does nothing. The admin order view is unchanged.
                    ]]></comment>
                </field>
            </group>
        </section>
    </system>
</config>
