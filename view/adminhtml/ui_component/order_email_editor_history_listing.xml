<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">order_email_editor_history_listing.order_email_editor_history_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>order_email_editor_history_columns</spinner>
        <deps>
            <dep>order_email_editor_history_listing.order_email_editor_history_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="order_email_editor_history_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">history_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>ETechFlow_OrderEmailEditor::view_history</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="order_email_editor_history_listing_data_source">
            <settings>
                <requestFieldName>history_id</requestFieldName>
                <primaryFieldName>history_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="order_email_editor_history_columns">
        <settings>
            <editorConfig>
                <param name="enabled" xsi:type="boolean">false</param>
            </editorConfig>
        </settings>

        <column name="history_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
            </settings>
        </column>

        <column name="increment_id" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Order #</label>
            </settings>
        </column>

        <column name="old_email" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Old Email</label>
            </settings>
        </column>

        <column name="new_email" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">New Email</label>
            </settings>
        </column>

        <column name="changed_by_admin_name" sortOrder="50">
            <settings>
                <filter>text</filter>
                <label translate="true">Changed By</label>
            </settings>
        </column>

        <column name="customer_record_updated" component="Magento_Ui/js/grid/columns/select" sortOrder="60">
            <settings>
                <options class="ETechFlow\OrderEmailEditor\Model\Source\YesNo"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Customer Record Updated</label>
            </settings>
        </column>

        <column name="ip_address" sortOrder="70">
            <settings>
                <filter>text</filter>
                <label translate="true">IP Address</label>
            </settings>
        </column>

        <column name="changed_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="80">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Changed At</label>
            </settings>
        </column>
    </columns>
</listing>
